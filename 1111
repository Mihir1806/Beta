Sub Export_Full_To_CSV()

    Dim ws As Worksheet
    Dim tempWB As Workbook
    Dim tempWS As Worksheet
    Dim lastRow As Long
    Dim lastCol As Long
    Dim filePath As String
    Dim r As Long, c As Long

    ' Sheet name
    Set ws = ThisWorkbook.Sheets("Result_V2")

    ' Find last row & column
    lastRow = ws.Cells.Find("*", SearchOrder:=xlByRows, SearchDirection:=xlPrevious).Row
    lastCol = ws.Cells.Find("*", SearchOrder:=xlByColumns, SearchDirection:=xlPrevious).Column

    ' Create temp workbook
    Set tempWB = Workbooks.Add
    Set tempWS = tempWB.Sheets(1)

    ' Copy full data
    ws.Range(ws.Cells(1, 1), ws.Cells(lastRow, lastCol)).Copy
    tempWS.Range("A1").PasteSpecial xlPasteValues

    ' Convert all dates to YYYY-MM-DD
    For r = 2 To lastRow
        For c = 1 To lastCol
            If IsDate(tempWS.Cells(r, c).Value) Then
                tempWS.Cells(r, c).Value = Format(tempWS.Cells(r, c).Value, "yyyy-mm-dd")
            End If
        Next c
    Next r

    ' Convert all to text (prevents Excel reformat)
    tempWS.Cells.NumberFormat = "@"

    ' File path
    filePath = ThisWorkbook.Path & "\Output_Full.csv"

    Application.DisplayAlerts = False

    ' Save as CSV
    tempWB.SaveAs Filename:=filePath, FileFormat:=xlCSV, CreateBackup:=False

    tempWB.Close False

    Application.DisplayAlerts = True

    MsgBox "Full CSV Created Successfully!"

End Sub