Sub Export_SDMX_CSV()

    Dim ws As Worksheet
    Dim lastRow As Long, i As Long
    Dim filePath As String
    Dim fileNum As Integer

    Set ws = ThisWorkbook.Sheets("Result")

    ' Safe file path
    If ThisWorkbook.Path = "" Then
        filePath = Environ("USERPROFILE") & "\Desktop\Result_SDMX.csv"
    Else
        filePath = ThisWorkbook.Path & "\Result_SDMX.csv"
    End If

    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row

    fileNum = FreeFile
    Open filePath For Output As #fileNum

    ' Header
    Print #fileNum, "DATAFLOW,REF_AREA,TIME_PERIOD,OBS_VALUE,UNIT"

    ' Data
    For i = 2 To lastRow
        If ws.Cells(i, "E").Value <> "" Then
            Print #fileNum, _
            ws.Cells(i, "A").Value & "," & _
            "IND" & "," & _
            Format(ws.Cells(i, "E").Value, "yyyy-mm-dd") & "," & _
            ws.Cells(i, "D").Value & "," & _
            ws.Cells(i, "I").Value
        End If
    Next i

    Close #fileNum

    MsgBox "SDMX CSV created successfully!"

End Sub