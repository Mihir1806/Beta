Sub Format_Result_Tab()

    Dim ws As Worksheet
    Dim lastRow As Long
    Dim tempWB As Workbook
    Dim tempWS As Worksheet
    Dim conn As WorkbookConnection

    Set ws = ThisWorkbook.Sheets("Result")

    Application.ScreenUpdating = False
    Application.DisplayAlerts = False

    ' Refresh only when macro runs (no background wait)
    For Each conn In ThisWorkbook.Connections
        On Error Resume Next
        conn.OLEDBConnection.BackgroundQuery = False
        conn.ODBCConnection.BackgroundQuery = False
        On Error GoTo 0
    Next conn
    ThisWorkbook.RefreshAll

    ' Find last row in Column E
    lastRow = ws.Cells(ws.Rows.Count, "E").End(xlUp).Row

    ' Formatting
    With ws
        .Columns("A:D").NumberFormat = "@"
        .Columns("F:J").NumberFormat = "@"
    End With

    ' Convert Column E to yyyy-mm-dd (TEXT for CSV) safely
    If lastRow >= 2 Then
        ws.Range("E2:E" & lastRow).NumberFormat = "@"
        ws.Range("E2:E" & lastRow).Value = ws.Evaluate( _
            "IF(E2:E" & lastRow & "<>"""",TEXT(E2:E" & lastRow & ",""yyyy-mm-dd""),"""")")
    End If

    ' Create temp workbook and copy only A:J
    Set tempWB = Workbooks.Add
    Set tempWS = tempWB.Sheets(1)

    ws.Range("A:J").Copy
    tempWS.Range("A1").PasteSpecial xlPasteValues

    ' Save as CSV
    tempWB.SaveAs Filename:=ThisWorkbook.Path & "\Result.csv", FileFormat:=xlCSV
    tempWB.Close False

    Application.DisplayAlerts = True
    Application.ScreenUpdating = True

End Sub