Sub Export_SDMX_CSV()

    Dim ws As Worksheet
    Dim lastRow As Long, i As Long
    Dim filePath As String
    Dim line As String
    Dim fso As Object, file As Object

    Set ws = ThisWorkbook.Sheets("Result")

    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row
    filePath = ThisWorkbook.Path & "\Result_SDMX.csv"

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set file = fso.CreateTextFile(filePath, True, False)

    ' Write Header (SDMX format)
    file.WriteLine "DATAFLOW,REF_AREA,TIME_PERIOD,OBS_VALUE,UNIT"

    ' Loop data
    For i = 2 To lastRow
        
        If ws.Cells(i, "E").Value <> "" Then
            
            line = ws.Cells(i, "A").Value & "," & _
                   "IND" & "," & _
                   Format(ws.Cells(i, "E").Value, "yyyy-mm-dd") & "," & _
                   ws.Cells(i, "D").Value & "," & _
                   ws.Cells(i, "I").Value

            file.WriteLine line
        
        End If
    Next i

    file.Close

    MsgBox "SDMX CSV Created Successfully!"

End Sub